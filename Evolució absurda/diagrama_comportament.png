<svg width="680" height="820" viewBox="0 0 680 820" xmlns="http://www.w3.org/2000/svg">

<defs>
  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
    <path d="M2 1L8 5L2 9" fill="none" stroke="#73726c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </marker>
</defs>

<!-- Fons blanc -->
<rect width="680" height="820" fill="white"/>

<!-- Inici -->
<g>
  <circle cx="340" cy="40" r="20" fill="#3d3d3a" opacity="0.8"/>
  <text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="340" y="75" text-anchor="middle">Inici partida</text>
</g>

<!-- Aparèixer al mapa -->
<g>
  <rect x="240" y="110" width="200" height="56" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#26215C" x="340" y="128" text-anchor="middle" dominant-baseline="central">Aparèixer al mapa</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="340" y="146" text-anchor="middle" dominant-baseline="central">Forma inicial: Pedra</text>
</g>

<line x1="340" y1="60" x2="340" y2="110" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Bucle principal -->
<rect x="180" y="190" width="320" height="540" rx="12" fill="none" stroke="#B4B2A9" stroke-width="2" stroke-dasharray="8 4"/>
<text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#3d3d3a" x="340" y="212" text-anchor="middle">Bucle principal</text>

<!-- Moure's -->
<g>
  <rect x="240" y="240" width="200" height="56" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#0C447C" x="340" y="258" text-anchor="middle" dominant-baseline="central">Moure's pel mapa</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="340" y="276" text-anchor="middle" dominant-baseline="central">WASD o teclat direccional</text>
</g>

<line x1="340" y1="166" x2="340" y2="240" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Decisió: Energia a prop? -->
<g>
  <path d="M340 330 L400 360 L340 390 L280 360 Z" fill="#FAEEDA" stroke="#854F0B" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#633806" x="340" y="360" text-anchor="middle" dominant-baseline="central">Energia</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="340" y="376" text-anchor="middle" dominant-baseline="central">a prop?</text>
</g>

<line x1="340" y1="296" x2="340" y2="330" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Sí: Recollir energia -->
<g>
  <rect x="460" y="342" width="180" height="56" rx="8" fill="#EAF3DE" stroke="#3B6D11" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#27500A" x="550" y="360" text-anchor="middle" dominant-baseline="central">Recollir energia</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#27500A" x="550" y="378" text-anchor="middle" dominant-baseline="central">+10 energia</text>
</g>

<line x1="400" y1="360" x2="460" y2="360" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="430" y="350" text-anchor="middle">Sí</text>

<!-- Decisió: Zona de perill? -->
<g>
  <path d="M340 440 L400 470 L340 500 L280 470 Z" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#712B13" x="340" y="470" text-anchor="middle" dominant-baseline="central">Zona</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="340" y="486" text-anchor="middle" dominant-baseline="central">perill?</text>
</g>

<line x1="340" y1="390" x2="340" y2="440" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="350" y="415" text-anchor="start">No</text>

<line x1="550" y1="398" x2="550" y2="470" x2="400" y2="470" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Sí perill: Rebre dany -->
<g>
  <rect x="60" y="442" width="160" height="56" rx="8" fill="#FCEBEB" stroke="#A32D2D" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#791F1F" x="140" y="460" text-anchor="middle" dominant-baseline="central">Rebre dany</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#791F1F" x="140" y="478" text-anchor="middle" dominant-baseline="central">Perdre energia</text>
</g>

<line x1="280" y1="470" x2="220" y2="470" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="250" y="460" text-anchor="middle">Sí</text>

<!-- Decisió: Mort? -->
<g>
  <path d="M140 540 L180 570 L140 600 L100 570 Z" fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#444441" x="140" y="570" text-anchor="middle" dominant-baseline="central">Mort?</text>
</g>

<line x1="140" y1="498" x2="140" y2="540" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Sí mort: Fi -->
<g>
  <circle cx="50" cy="670" r="20" fill="none" stroke="#3d3d3a" stroke-width="3" opacity="0.8"/>
  <circle cx="50" cy="670" r="14" fill="#3d3d3a" opacity="0.8"/>
  <text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="50" y="705" text-anchor="middle">Fi de partida</text>
</g>

<line x1="100" y1="570" x2="50" y2="570" x2="50" y2="650" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="70" y="560" text-anchor="start">Sí</text>

<!-- No mort: Continuar -->
<line x1="180" y1="570" x2="220" y2="570" x2="220" y2="268" x2="240" y2="268" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="190" y="560" text-anchor="start">No</text>

<!-- Decisió: Prou energia per evolucionar? -->
<g>
  <path d="M340 550 L410 580 L340 610 L270 580 Z" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#085041" x="340" y="576" text-anchor="middle" dominant-baseline="central">Energia ≥</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="340" y="592" text-anchor="middle" dominant-baseline="central">llindar?</text>
</g>

<line x1="340" y1="500" x2="340" y2="550" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="350" y="525" text-anchor="start">No</text>

<!-- Sí evolució: Evolucionar -->
<g>
  <rect x="460" y="552" width="180" height="74" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#26215C" x="550" y="572" text-anchor="middle" dominant-baseline="central">Evolucionar</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="550" y="590" text-anchor="middle" dominant-baseline="central">Nova forma</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="550" y="608" text-anchor="middle" dominant-baseline="central">Nova habilitat</text>
</g>

<line x1="410" y1="580" x2="460" y2="580" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="435" y="570" text-anchor="middle">Sí</text>

<!-- Tornar al bucle després d'evolucionar -->
<line x1="550" y1="626" x2="550" y2="660" x2="340" y2="660" x2="340" y2="240" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Tornar al bucle sense evolucionar -->
<line x1="270" y1="580" x2="250" y2="580" x2="250" y2="268" x2="240" y2="268" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="260" y="570" text-anchor="end">No</text>

<!-- Etiqueta bucle -->
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="195" y="268" text-anchor="end" opacity="0.6">Continuar jugant</text>

</svg>
