<svg width="680" height="580" viewBox="0 0 680 580" xmlns="http://www.w3.org/2000/svg">
<defs>
  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
    <path d="M2 1L8 5L2 9" fill="none" stroke="#73726c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </marker>
</defs>

<!-- Fons blanc -->
<rect width="680" height="580" fill="white"/>

<!-- Jugador -->
<g>
  <rect x="40" y="40" width="200" height="180" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
  <rect x="40" y="40" width="200" height="36" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#26215C" x="140" y="62" text-anchor="middle" dominant-baseline="central">Jugador</text>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="92">+ energiaActual: number</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="110">+ nivelEvolucio: number</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="128">+ velocitat: number</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="146">+ modelActual: Model</text>
  
  <line x1="40" y1="158" x2="240" y2="158" stroke="#73726c" stroke-width="0.5" opacity="0.3"/>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="176">+ moure()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="194">+ recollirEnergia()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#26215C" x="52" y="212">+ utilitzarHabilitat()</text>
</g>

<!-- SistemaEvolucio -->
<g>
  <rect x="280" y="40" width="200" height="180" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <rect x="280" y="40" width="200" height="36" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#085041" x="380" y="62" text-anchor="middle" dominant-baseline="central">SistemaEvolucio</text>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="92">+ llindarEvolucio: array</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="110">+ habilitats: array</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="128">+ models: array</text>
  
  <line x1="280" y1="140" x2="480" y2="140" stroke="#73726c" stroke-width="0.5" opacity="0.3"/>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="158">+ comprovarEvolucio()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="176">+ aplicarEvolucio()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="194">+ desbloquearHabilitat()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#085041" x="292" y="212">+ canviarModel()</text>
</g>

<!-- Relació Jugador - SistemaEvolucio -->
<path d="M240 130 L280 130" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="260" y="120" text-anchor="middle">utilitza</text>

<!-- Energia -->
<g>
  <rect x="520" y="40" width="140" height="140" rx="8" fill="#FAEEDA" stroke="#854F0B" stroke-width="0.5"/>
  <rect x="520" y="40" width="140" height="36" rx="8" fill="#FAEEDA" stroke="#854F0B" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#633806" x="590" y="62" text-anchor="middle" dominant-baseline="central">Energia</text>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="532" y="92">+ valor: number</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="532" y="110">+ posicio: Vector3</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="532" y="128">+ activa: boolean</text>
  
  <line x1="520" y1="140" x2="660" y2="140" stroke="#73726c" stroke-width="0.5" opacity="0.3"/>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="532" y="158">+ aparixer()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#633806" x="532" y="176">+ desaparixer()</text>
</g>

<!-- Relació Jugador - Energia -->
<path d="M140 220 Q140 260 590 260 L590 180" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="320" y="270" text-anchor="middle">recull</text>

<!-- ZonaPerill -->
<g>
  <rect x="40" y="280" width="180" height="140" rx="8" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
  <rect x="40" y="280" width="180" height="36" rx="8" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#712B13" x="130" y="302" text-anchor="middle" dominant-baseline="central">ZonaPerill</text>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="52" y="332">+ tipus: string</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="52" y="350">+ dany: number</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="52" y="368">+ area: Region3</text>
  
  <line x1="40" y1="380" x2="220" y2="380" stroke="#73726c" stroke-width="0.5" opacity="0.3"/>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="52" y="398">+ detectarJugador()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#712B13" x="52" y="416">+ aplicarDany()</text>
</g>

<!-- Relació Jugador - ZonaPerill -->
<path d="M140 220 L140 280" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="150" y="250" text-anchor="start">evita</text>

<!-- Mapa -->
<g>
  <rect x="280" y="280" width="200" height="160" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <rect x="280" y="280" width="200" height="36" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#0C447C" x="380" y="302" text-anchor="middle" dominant-baseline="central">Mapa</text>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="332">+ zones: array</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="350">+ energies: array</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="368">+ jugadors: array</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="386">+ tamany: Vector3</text>
  
  <line x1="280" y1="398" x2="480" y2="398" stroke="#73726c" stroke-width="0.5" opacity="0.3"/>
  
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="416">+ generarEnergia()</text>
  <text font-family="Arial, sans-serif" font-size="12" fill="#0C447C" x="292" y="434">+ actualitzar()</text>
</g>

<!-- Relació Mapa - ZonaPerill -->
<path d="M280 350 L220 350" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="250" y="340" text-anchor="middle">conté</text>

<!-- Relació Mapa - Energia -->
<path d="M480 320 L520 200 L520 180" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="505" y="240" text-anchor="end">genera</text>

<!-- Relació Mapa - Jugador -->
<path d="M380 280 L380 220" fill="none" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="390" y="250" text-anchor="start">gestiona</text>

<!-- Llegenda -->
<text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#3d3d3a" x="40" y="490" dominant-baseline="central">Relacions:</text>
<line x1="40" y1="510" x2="80" y2="510" stroke="#73726c" stroke-width="1.5" marker-end="url(#arrow)"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="90" y="510" dominant-baseline="central">Associació / Dependència</text>

<text font-family="Arial, sans-serif" font-size="14" font-weight="500" fill="#3d3d3a" x="40" y="540" dominant-baseline="central">Colors:</text>
<rect x="40" y="552" width="16" height="16" rx="3" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="62" y="560" dominant-baseline="central">Jugador</text>

<rect x="140" y="552" width="16" height="16" rx="3" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="162" y="560" dominant-baseline="central">Sistema</text>

<rect x="240" y="552" width="16" height="16" rx="3" fill="#FAEEDA" stroke="#854F0B" stroke-width="0.5"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="262" y="560" dominant-baseline="central">Recursos</text>

<rect x="340" y="552" width="16" height="16" rx="3" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="362" y="560" dominant-baseline="central">Perills</text>

<rect x="440" y="552" width="16" height="16" rx="3" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
<text font-family="Arial, sans-serif" font-size="12" fill="#5F5E5A" x="462" y="560" dominant-baseline="central">Entorn</text>

</svg>
